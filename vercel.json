{
  "buildCommand": "pnpm install && pnpm build",
  "outputDirectory": "dist",
  "functions": {
    "api/db.ts": {
      "runtime": "@vercel/node@18.17.1"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
